# Equilibrium Terminal — environment variables

# Auth (required in production)
EQUILIBRIUM_JWT_SECRET=your-secret-min-32-characters-long

# Institutional news wire (optional — unlocks full squawk-grade feed)
# Tree of Alpha: https://news.treeofalpha.com/account
EQUILIBRIUM_TREE_NEWS_API_KEY=

# CryptoPanic 70+ source aggregator (important / hot / rising filters)
# Sign up: https://cryptopanic.com/developers/api/ — add token in Vercel env
EQUILIBRIUM_CRYPTOPANIC_AUTH_TOKEN=

# FRED macro desk (optional — free API key unlocks CPI, unemployment, 10Y, fed funds)
# Register: https://fred.stlouisfed.org/docs/api/api_key.html
EQUILIBRIUM_FRED_API_KEY=

# Webhook HMAC signing (optional — adds X-Equilibrium-Signature header on outbound POSTs)
EQUILIBRIUM_WEBHOOK_SIGNING_SECRET=

# Durable server audit (optional — Vercel KV / Upstash; survives redeploys)
# Create KV in Vercel dashboard → Storage → Connect to project (auto-sets vars below)
KV_REST_API_URL=
KV_REST_API_TOKEN=
# EQUILIBRIUM_AUDIT_KV_KEY=eq-audit-log

# Alpha launch (opt-in — set to 1 only when you want the invite gate on production)
# NEXT_PUBLIC_EQ_ALPHA_INVITE_REQUIRED=1
# Bypass gate entirely for operator desks:
# NEXT_PUBLIC_EQ_OPERATOR_ACCESS=true
NEXT_PUBLIC_EQ_ALPHA_CODES=EQ-ALPHA-2026,EQ-HL-DESK,EQ-EXEC

# Hyperliquid builder code (optional override — defaults to Equilibrium builder)
NEXT_PUBLIC_EQUILIBRIUM_BUILDER_ADDRESS=0xad9be64fd7a35d99a138b87cb212baefbcdcf045
