{
  "name": "equilibrium-terminal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node -e \"try{require('fs').rmSync('node_modules/.cache/equilibrium-next-dev',{recursive:true,force:true})}catch(e){}\" && next dev",
    "serve": "npm run build && next start",
    "start:local": "next start",
    "restart": "powershell -ExecutionPolicy Bypass -File ./scripts/restart-terminal.ps1",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "publish:vercel": "npm run build && npx vercel --prod"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.2",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@tanstack/react-query": "^5.66.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "lightweight-charts": "^4.2.3",
    "lucide-react": "^0.475.0",
    "next": "^14.2.24",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-grid-layout": "^1.5.0",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "viem": "^2.23.5",
    "wagmi": "^2.14.12",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/react-grid-layout": "^1.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.24",
    "postcss": "^8.5.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  }
}
